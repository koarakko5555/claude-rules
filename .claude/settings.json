{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git rev-parse*)",
      "Bash(git show*)",
      "Bash(git remote -v)",
      "Bash(git remote show*)",
      "Bash(git stash list*)",
      "Bash(git add *)",
      "Bash(ls*)",
      "Bash(find . *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(file *)",
      "Bash(wc *)",
      "Bash(mkdir -p *)",
      "Bash(chmod +x *)",
      "Bash(npm test*)",
      "Bash(npm run test*)",
      "Bash(npm run lint*)",
      "Bash(npm run typecheck*)",
      "Bash(npx prettier *)",
      "Bash(npx tsc --noEmit*)",
      "Bash(pytest*)",
      "Bash(ruff check*)",
      "Bash(ruff format*)",
      "Bash(go test*)",
      "Bash(go vet*)",
      "Bash(cargo test*)",
      "Bash(cargo check*)",
      "Bash(gh auth status)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh repo view*)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(rm -rf /)",
      "Bash(sudo rm*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-context.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/format.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude has stopped\" with title \"Claude Code\"' 2>/dev/null || echo -e '\\a'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[PreToolUse] Bash: $CLAUDE_TOOL_INPUT\" >> /tmp/claude-audit.log 2>/dev/null; true"
          }
        ]
      }
    ]
  }
}
